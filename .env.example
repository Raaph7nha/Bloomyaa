# Configuración de Servidor
PORT=3000
NODE_ENV=development
JWT_SECRET=secreto

# Base de Datos (PostgreSQL)
DATABASE_URL=postgres://usuario:password@host:port/database

# Perenual API (Catálogo de plantas)
PERENUAL_API_KEY=

# Pl@ntNet API (Identificación de plantas)
PLANTNET_API_KEY=

# Cloudinary (Almacenamiento de imágenes)
CLOUDINARY_CLOUD=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gemini AI (Para identificación y descripciones - Frontend)
GEMINI_API_KEY=

# Groq AI (Para descripciones - Backend)
GROQ_API_KEY=

# Pexels API (Fallback de imágenes)
PEXELS_API_KEY=

# Mercado Pago
MP_PUBLIC_KEY=
VITE_MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
APP_URL=
